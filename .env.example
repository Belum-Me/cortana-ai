ANTHROPIC_API_KEY=your_api_key_here

# Email (opcional)
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASSWORD=tu_app_password

# Telegram (opcional)
TELEGRAM_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# Picovoice Porcupine - wake word local (opcional pero recomendado)
# Obtén tu key gratis en: https://console.picovoice.ai/signup
PICOVOICE_KEY=your_picovoice_key_here

# Wake word built-in (sin PICOVOICE_KEY usa Google STT como fallback)
# Opciones disponibles: jarvis, computer, terminator, alexa, bumblebee, porcupine
PORCUPINE_KEYWORD=jarvis

# Modelo personalizado "cortana" (opcional)
# Descarga desde: https://console.picovoice.ai -> Wake Word -> Custom
# PORCUPINE_MODEL_PATH=C:\Users\sierr\cortana\cortana_es_windows.ppn
